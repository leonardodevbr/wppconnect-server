# Servidor
NODE_ENV=production
PORT=3000
SECRET_KEY=

# CORS — separar múltiplas origens por vírgula
ALLOWED_ORIGINS=https://seu-frontend.vercel.app

# MongoDB — usar a URI gerada pelo plugin Railway
MONGODB_URI=

# Redis — usar as variáveis geradas pelo plugin Railway
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Webhook padrão (opcional) — também aceita CALLBACK_URL para compatibilidade
WEBHOOK_URL=

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=
